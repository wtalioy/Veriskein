{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriskein.local/schemas/alert.schema.json",
  "title": "VeriskeinAlert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "alert_id",
    "ts_ns",
    "type",
    "severity",
    "confidence_band",
    "confidence_score",
    "pid",
    "tid",
    "session_id",
    "summary",
    "reason_code",
    "objects",
    "evidence",
    "fallback",
    "policy"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "alert_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "ts_ns": { "type": "integer", "minimum": 0 },
    "type": {
      "enum": [
        "exec_observed",
        "unexpected_shell",
        "sensitive_file_access",
        "out_of_workspace_deletion"
      ]
    },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "confidence_band": { "enum": ["weak", "medium", "strong"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "pid": { "type": "integer", "minimum": 0 },
    "tid": { "type": "integer", "minimum": 0 },
    "session_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "agent_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{32}$|^$" },
    "summary": { "type": "string", "maxLength": 512 },
    "reason_code": { "type": "string", "maxLength": 64 },
    "objects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths", "event_ids", "argv"],
      "properties": {
        "paths": { "type": "array", "items": { "type": "string" } },
        "event_ids": { "type": "array", "items": { "type": "string" } },
        "argv": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "event_id", "ingest_seq"],
        "properties": {
          "kind": {
            "enum": ["syscall", "file_access", "net_connect", "prompt_ref", "heuristic"]
          },
          "event_id": { "type": "string", "minLength": 1 },
          "ingest_seq": { "type": "integer", "minimum": 0 },
          "path": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"] }
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "visibility"],
      "properties": {
        "mode": { "enum": ["none", "degraded", "capture_disabled", "prompt_evidence_unavailable"] },
        "visibility": { "enum": ["full", "partial", "unsupported", "unavailable"] }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector_version", "policy_version"],
      "properties": {
        "detector_version": { "type": "integer", "minimum": 1 },
        "policy_version": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
