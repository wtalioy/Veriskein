{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriskein.local/schemas/alert.schema.json",
  "title": "VeriskeinAlert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "alert_id",
    "ts_ns",
    "type",
    "severity",
    "confidence_band",
    "confidence_score",
    "pid",
    "tid",
    "session_id",
    "summary",
    "reason_code",
    "objects",
    "evidence",
    "fallback",
    "policy",
    "capture"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "cross_agent_prompt_injection" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "objects": {
            "required": [
              "prompt_ids",
              "artifact_ids",
              "chain_id",
              "root_session_id",
              "downstream_session_id"
            ],
            "properties": {
              "prompt_ids": { "minItems": 1 },
              "artifact_ids": { "minItems": 1 },
              "chain_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
              "root_session_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
              "downstream_session_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "alert_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "ts_ns": { "type": "integer", "minimum": 0 },
    "type": {
      "enum": [
        "exec_observed",
        "unexpected_shell",
        "sensitive_file_access",
        "out_of_workspace_deletion",
        "single_agent_deadloop",
        "cross_agent_prompt_injection",
        "mcp_tool_spoofing"
      ]
    },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "confidence_band": { "enum": ["weak", "medium", "strong"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "pid": { "type": "integer", "minimum": 0 },
    "tid": { "type": "integer", "minimum": 0 },
    "session_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "agent_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{32}$|^$" },
    "summary": { "type": "string", "maxLength": 512 },
    "reason_code": { "type": "string", "maxLength": 64 },
    "objects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths", "event_ids", "argv"],
      "properties": {
        "paths": { "type": "array", "items": { "type": "string" } },
        "ips": { "type": "array", "items": { "type": "string" }, "default": [] },
        "ports": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 65535 }, "default": [] },
        "prompt_ids": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-f]{32}$" }, "default": [] },
        "artifact_ids": { "type": "array", "items": { "type": "string", "pattern": "^[0-9a-f]{32}$" }, "default": [] },
        "event_ids": { "type": "array", "items": { "type": "string" } },
        "chain_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{32}$|^$" },
        "workspace_id": { "type": ["string", "null"] },
        "root_session_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{32}$|^$" },
        "downstream_session_id": { "type": ["string", "null"], "pattern": "^[0-9a-f]{32}$|^$" },
        "argv": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "event_id", "ingest_seq"],
        "properties": {
          "kind": {
            "enum": ["excerpt_match", "syscall", "file_access", "net_connect", "prompt_ref", "artifact_ref", "heuristic", "mcp_registry"]
          },
          "event_id": { "type": "string", "minLength": 1 },
          "ingest_seq": { "type": "integer", "minimum": 0 },
          "path": { "type": ["string", "null"] },
          "ip": { "type": ["string", "null"] },
          "port": { "type": ["integer", "null"], "minimum": 0, "maximum": 65535 },
          "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "src": { "type": ["string", "null"] },
          "dst": { "type": ["string", "null"] },
          "op": { "type": ["string", "null"] },
          "note": { "type": ["string", "null"] }
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "visibility"],
      "properties": {
        "mode": { "enum": ["none", "degraded", "capture_disabled", "prompt_evidence_unavailable"] },
        "visibility": { "enum": ["full", "partial", "unsupported", "unavailable"] },
        "prompt_evidence": { "enum": ["available", "partial", "unavailable"] },
        "degradation_sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detector_version", "policy_version", "component_scores"],
      "properties": {
        "detector_version": { "type": "integer", "minimum": 1 },
        "policy_version": { "type": "integer", "minimum": 1 },
        "component_scores": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "redaction"],
      "properties": {
        "mode": { "enum": ["none", "tls"] },
        "redaction": { "enum": ["none", "masked"] }
      }
    },
    "explanation": { "type": ["string", "null"], "maxLength": 512 }
  }
}
