{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriskein.local/schemas/alert.schema.json",
  "title": "VeriskeinAlert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "type",
    "severity",
    "confidence_band",
    "timestamp",
    "process",
    "session",
    "evidence",
    "objects",
    "fallback"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "type": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "confidence_band": { "enum": ["weak", "medium", "strong"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pid", "tgid", "tid", "comm", "binary"],
      "properties": {
        "pid": { "type": "integer", "minimum": 0 },
        "tgid": { "type": "integer", "minimum": 0 },
        "tid": { "type": "integer", "minimum": 0 },
        "comm": { "type": "string" },
        "binary": { "type": "string" }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "workspace"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "workspace": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "event_id", "ingest_seq"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "event_id": { "type": "string", "minLength": 1 },
          "ingest_seq": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "objects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_kind", "argv"],
      "properties": {
        "event_kind": { "type": "string", "minLength": 1 },
        "argv": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "visibility"],
      "properties": {
        "mode": { "enum": ["none", "degraded", "capture_disabled", "prompt_evidence_unavailable"] },
        "visibility": { "enum": ["full", "partial", "unsupported", "unavailable"] }
      }
    }
  }
}

